{
  "tasks": {
    "dev": "deno run -A --watch --unstable-kv main.ts",
    "start": "deno run -A --unstable-kv main.ts",
    "build": "deno run -A --unstable-kv main.ts build",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "test": "deno test -A"
  },
  "imports": {
    "$fresh/": "https://deno.land/x/fresh@1.6.5/",
    "fresh/": "https://deno.land/x/fresh@1.6.5/",
    "preact": "https://esm.sh/preact@10.19.3",
    "preact/": "https://esm.sh/preact@10.19.3/",
    "preact/hooks": "https://esm.sh/preact@10.19.3/hooks",
    "@preact/signals": "https://esm.sh/@preact/signals@1.2.1",
    "@preact/signals-core": "https://esm.sh/@preact/signals-core@1.5.0",
    "gfm": "https://deno.land/x/gfm@0.2.4/mod.ts"
  },
  "lint": {
    "exclude": ["test-*.ts", "*.test.ts"],
    "rules": {
      "tags": ["recommended"]
    }
  },
  "fmt": {
    "exclude": ["www", "node_modules", "static"]
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  }
}
